<configuration>

    <!-- 控制台输出：只显示 WARN 及以上的日志，避免干扰用户交互 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{HH:mm:ss} [%level] %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出：记录所有 DEBUG 及以上日志，方便排查问题 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/kingdee-qa.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 每天轮转，保留 7 天 -->
            <fileNamePattern>logs/kingdee-qa.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 屏蔽 LangChain4j 内部的详细日志 -->
    <logger name="dev.langchain4j" level="WARN"/>
    <logger name="okhttp3" level="WARN"/>

    <!-- 我们自己的代码保留 INFO -->
    <logger name="com.kingdee.qa" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
